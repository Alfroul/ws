{
  "name": "ws-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Developer workspace manager",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.js",
    "test": "npx vitest run",
    "typecheck": "npx tsc --noEmit",
    "clean": "node -e \"import('node:fs').then(fs=>{for(const p of['packages/utils/dist','packages/config/dist','packages/git/dist','packages/docker/dist','packages/process/dist','packages/plugin-api/dist','packages/core/dist','packages/cli/dist'])fs.rmSync(p,{recursive:true,force:true})})\""
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0",
    "js-yaml": "^4.1.0",
    "@types/js-yaml": "^4.0.9",
    "commander": "^12.1.0",
    "@inquirer/prompts": "^7.3.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "isomorphic-git": "^1.27.0",
    "dockerode": "^4.0.2",
    "@types/dockerode": "^3.3.31"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
